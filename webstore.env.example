# Chrome Web Store upload settings
set CWS_EXTENSION_ID=your_extension_id
set CWS_CLIENT_ID=your_google_oauth_client_id
set CWS_CLIENT_SECRET=your_google_oauth_client_secret
set CWS_REFRESH_TOKEN=your_google_oauth_refresh_token

# Enable upload in build-all.bat
set CWS_UPLOAD=1

# Optional: publish immediately after upload
set CWS_PUBLISH=1
